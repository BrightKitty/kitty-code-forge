{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "node",
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "skipLibCheck": true,
    "strict":true,
    //"strictNullChecks": false
  },
  
  "include": ["src"],
  "references": [
    {"path":"./tsconfig.app.json"},
    {"path": "./tsconfig.node.json"}
  ]
}